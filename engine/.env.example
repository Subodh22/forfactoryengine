# Copy to engine/.env to enable "Login with GitHub".
#
# Create a GitHub OAuth App: github.com → Settings → Developer settings →
# OAuth Apps → New OAuth App
#   Homepage URL:               http://localhost:5173
#   Authorization callback URL: http://localhost:8787/api/github/callback
# Then copy the Client ID and a generated Client Secret here:

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional overrides (defaults shown — fine for local dev):
# FACTORY_OAUTH_CALLBACK=http://localhost:8787/api/github/callback
# FACTORY_APP_URL=http://localhost:5173

# Optional: gate the engine with a token (required for any online deploy)
# FACTORY_AUTH_TOKEN=

# Optional: Turso cloud read-replica (phone access)
# TURSO_DATABASE_URL=
# TURSO_AUTH_TOKEN=
