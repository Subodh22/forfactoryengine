# TEMPLATE ONLY — do not put real secrets here (this file is committed to git).
# Real values go in web/.env.local (local dev) or Vercel's Environment Variables.

# Turso (the DB the engine syncs with — same values as engine/.env)
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=

# GitHub OAuth — "Login with GitHub" happens here on the Vercel site.
# Create an OAuth App (github.com → Settings → Developer settings → OAuth Apps):
#   Homepage URL:               https://your-app.vercel.app
#   Authorization callback URL: https://your-app.vercel.app/api/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
